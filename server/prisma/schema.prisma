generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Post {
  id         String   @id @default(cuid())
  title      String
  content    String
  status     String   @default("draft")
  repoName   String
  branchName String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
